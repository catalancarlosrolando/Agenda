<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Mi Agenda</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" />
</head>

<body class="bg-light">
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-dark shadow-sm mb-3">
            <div class="container">
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-white" href="/">Eventos</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" href="/Contacto">Contacto</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3" id="main-content">
        </main>
    </div>

    <footer class="border-top footer text-muted mt-5 py-3 bg-white">
        <div class="container text-center">
            &copy; 2026 - Agenda Online .NET
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script type="module" src="~/js/Agenda.js"></script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>